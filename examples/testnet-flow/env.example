# Path to aptos-ts-sdk repo root (with examples/bun-confidential-testnet installed + built).
# Leave unset if aptos-ts-sdk is a sibling folder: ../aptos-ts-sdk next to confidential-asset-bindings.
# APTOS_TS_SDK_ROOT=/absolute/path/to/aptos-ts-sdk

# APTOS_NETWORK=testnet

# Ed25519 signing key (Testnet only). Use ONE of the following approaches:
APTOS_PRIVATE_KEY=
# FIXED_ED25519_PRIVATE_KEY=

# Optional override for confidential decryption key (hex); otherwise derived like TS SDK.
# APTOS_TWISTED_ED25519_PRIVATE_KEY=
